#!/bin/sh

update()
{

  # Color codes {{{
  RESET="\e[0m"

  RED="\e[00;31m"
  GREEN="\e[00;32m"
  YELLOW="\e[00;33m"
  BLUE="\e[00;34m"
  PURPLE="\e[00;35m"
  CYAN="\e[00;36m"
  GRAY="\e[00;37m"

  LRED="\e[01;31m"
  LGREEN="\e[01;32m"
  LYELLOW="\e[01;33m"
  LBLUE="\e[01;34m"
  LPURPLE="\e[01;35m"
  LCYAN="\e[01;36m"
  WHITE="\e[01;37m"
  # }}}

  sudo apt update --yes
  # sudo apt upgrade --yes
  sudo apt full-upgrade --yes
  sudo apt autoremove --yes


  # conda {{{
  if command -v conda > /dev/null 2>&1
  then

    # Remember the current conda environment if any.
    if [[ -n $CONDA_DEFAULT_ENV ]]
    then
        local conda_env=$CONDA_DEFAULT_ENV
    fi

    echo ''
    echo -e "${LGREEN}conda ${WHITE}updating ${LYELLOW}base ${RESET}"

    conda activate base
    conda update conda --yes
    conda update --all --yes

    # echo ''
    # echo -e '\e[32;1mconda \e[37;1mupdating \e[33;1mnvim \e[0m'
    #
    # conda activate nvim
    # conda update --all --yes

    # Очистить кэш
    conda clean --all --yes

    # # Restore conda environment
    # if [[ -n conda_env ]]
    # then
    #     conda activate $conda_env
    # else
    #     conda deactivate
    # fi

  fi
  # }}}

  # Homebrew {{{
  if command -v brew > /dev/null 2>&1
  then
    echo -e "${WHITE}Updating ${LYELLOW}Homebrew ${RESET}"
    brew update
    brew upgrade
  fi
  # }}}

  # Pipx apps {{{
  if command -v /usr/bin/pipx > /dev/null 2>&1
  then
    echo
    echo -e "${WHITE}Updating ${LGREEN}Pipx ${WHITE}apps ${RESET}"
    /usr/bin/pipx upgrade-all
  fi
  # }}}

  # Zinit {{{
  if command -v zinit > /dev/null 2>&1
  then
    echo
    echo -e "${WHITE}Updating ${LPURPLE}Zinit ${RESET}"
    zinit self-update
    zinit update --all
  fi
  # }}}

  # Tmux plugins {{{
  TMUX_PLUGIN_MANAGER="${HOME}/.local/share/tmux/plugins/tpm/bin/update_plugins"
  if [[ -s $TMUX_PLUGIN_MANAGER ]]
  then
    echo
    echo -e "${WHITE}Updating ${LGREEN}Tmux ${WHITE}plugins ${RESET}"
    $TMUX_PLUGIN_MANAGER all
  fi
  # }}}

}

# vim: ft=zsh
