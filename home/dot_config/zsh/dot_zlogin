#     ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚Ėą‚Ėą  ‚ĖĎ‚Ėą‚Ėą ‚Ėą‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚Ėą‚Ėą ‚Ėą‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚Ėą‚Ėą
#        ‚Ėą‚Ėą   ‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚Ėą‚Ėą  ‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚Ėą‚Ėą  ‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚Ėą‚Ėą  ‚ĖĎ‚Ėą‚Ėą
#       ‚Ėą‚Ėą    ‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚Ėą‚Ėą  ‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚ĖĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚Ėą‚Ėą  ‚ĖĎ‚Ėą‚Ėą
#  ‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą ‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚ĖĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚Ėą‚Ėą  ‚ĖĎ‚Ėą‚Ėą
# ‚ĖĎ‚ĖĎ  ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ  ‚ĖĎ‚ĖĎ  ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ    ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą ‚ĖĎ‚ĖĎ ‚ĖĎ‚ĖĎ   ‚ĖĎ‚ĖĎ
#                         ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ
#
# This file is like `.zprofile`, but is read after `.zshrc`. You can consider
# the shell to be fully set up at `.zlogin` execution time. This is not the
# file to define aliases, functions, shell options, and key bindings. It
# should not change the shell environment. It is usually used for messages
# such as [fortune][1], [msgs][2], or for the creation of files. Good idea
# is to use it to launch external commands which do not modify shell behaviors
# (e.g. a login manager).
#
# [1]: http://en.wikipedia.org/wiki/Fortune_(Unix)
# [2]: http://www.manpagez.com/man/1/msgs

{
  setopt LOCAL_OPTIONS EXTENDED_GLOB GLOB_DOTS
  autoload -U zrecompile

  if [[ -d ${ZDOTDIR} ]]; then
    zrecompile -pq "$ZDOTDIR/.zprofile"
    zrecompile -pq "$ZDOTDIR/.zshrc"
    zrecompile -pq "$ZDOTDIR/.zlogin"

    # Recompile all zsh and sh files.
    zrecompile -pq ${ZDOTDIR}/**/*.*sh(#qN)
    # zrecompile -pq {$ZDOTDIR/**,$HOME/.cache/zsh/**}/*.*sh(#qN)

    # Compile all functions in the single "digest" file.
    zrecompile -pq "${ZDOTDIR}/functions.zwc" ${ZDOTDIR}/functions/*(N.)
  fi

  if [[ -d $XDG_CACHE_HOME/zsh ]]; then
    zrecompile -pq $XDG_CACHE_HOME/zsh/**/*.*sh(#qN)
  fi

  # Delete all "*.zwc.old" files
  # (#qN) is glob qualifier which sets the NULL_GLOB option for the current
  # pattern, so it doesn't show message if no matches found.
  rm -f -- {${ZDOTDIR}/**,$XDG_CACHE_HOME/zsh/**}/*.zwc.old(#qN)

} &! # Execute code in the background to not affect the current session
