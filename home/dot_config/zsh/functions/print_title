function print_title {
    local filler='вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•вЂ•'
    local string="$(color white bold 'вЂ•вЂ•') $@"
    setopt local_options extended_glob
    local esc=$'\e'
