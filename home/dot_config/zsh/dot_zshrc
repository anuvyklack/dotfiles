#!/usr/bin/env zsh
#                     ‚Ėą‚Ėą
#                    ‚ĖĎ‚Ėą‚Ėą
#      ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ĖĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą
#     ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚Ėą‚Ėą  ‚Ėą‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ ‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚ĖĎ‚Ėą ‚Ėą‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚Ėą‚Ėą
#        ‚Ėą‚Ėą  ‚ĖĎ‚ĖĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą ‚ĖĎ‚Ėą‚Ėą  ‚ĖĎ‚Ėą‚Ėą ‚ĖĎ‚Ėą‚Ėą ‚ĖĎ ‚ĖĎ‚Ėą‚Ėą  ‚ĖĎ‚ĖĎ
#       ‚Ėą‚Ėą    ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚Ėą‚Ėą  ‚ĖĎ‚Ėą‚Ėą ‚ĖĎ‚Ėą‚Ėą   ‚ĖĎ‚Ėą‚Ėą   ‚Ėą‚Ėą
#  ‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą ‚ĖĎ‚Ėą‚Ėą  ‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚Ėą‚Ėą‚Ėą   ‚ĖĎ‚ĖĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą
# ‚ĖĎ‚ĖĎ  ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ  ‚ĖĎ‚ĖĎ   ‚ĖĎ‚ĖĎ ‚ĖĎ‚ĖĎ‚ĖĎ     ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ

zmodload zsh/param/private # private variables
zmodload zsh/complist      # completion menu

# * Autoload custom function

if [[ -d "${ZDOTDIR}/functions" ]]; then
  fpath+=("${ZDOTDIR}/functions")
  autoload -Uz $(echo -n $(find "$ZDOTDIR/functions/" -maxdepth 1 -type f))
fi

# * fzf
# https://github.com/junegunn/fzf

if (( $+commands[fzf] )); then
  export FZF_DEFAULT_OPTS='--height 70% --layout=reverse --border'
  export FZF_DEFAULT_COMMAND='rg --files --no-ignore --hidden --follow -g "!{.git,node_modules}" 2>/dev/null'
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

  if (( $+commands[bfs] )); then
    # Show all directories including hidden, follow symlinks.
    export FZF_ALT_C_COMMAND="bfs -type d -L -print 2>/dev/null"
  fi

  # fzf --zsh was added in fzf 0.48; fall back to system path for older builds.
  if fzf_integration=$(fzf --zsh 2>/dev/null); then
    eval "$fzf_integration"
  elif [[ -f /usr/share/fzf/shell/key-bindings.zsh ]]; then
    source /usr/share/fzf/shell/key-bindings.zsh
  fi
  unset fzf_integration
fi

# * fzf-tab
# https://github.com/Aloxaf/fzf-tab

() {
  local lc=$'\e[' rc=m
  local rgb="${lc}38;2;"
  local reset="${lc}0;${rc}"
  FZF_TAB_GROUP_COLORS=(
    "${rgb}171;178;191${rc}"
    "${rgb}157;226;199${rc}"
    "${rgb}226;157;226${rc}"
    "${rgb}205;212;96${rc}"
    "${rgb}115;184;241${rc}"
    "${rgb}241;167;173${rc}"
    "${rgb}229;192;123${rc}"
    "${rgb}209;179;255${rc}"
    "${rgb}164;210;121${rc}"
    "${rgb}162;176;246${rc}"
  )
  zstyle ':fzf-tab:*' group-colors $FZF_TAB_GROUP_COLORS
}
zstyle ':fzf-tab:*' prefix ''
zstyle ':fzf-tab:*' switch-group ',' '.'
zstyle ':completion:*:descriptions' format '-- %d --'

# * atuin
# https://github.com/atuinsh/atuin

if (( $+commands[atuin] )); then
  eval "$(atuin init zsh)"
fi

# * zoxide

if (( $+commands[zoxide] )); then
  _ZO_ECHO=1
fi

# * Emacs
# ** vterm

if [[ "$INSIDE_EMACS" = 'vterm' ]] \
    && [[ -n ${EMACS_VTERM_PATH} ]] \
    && [[ -f ${EMACS_VTERM_PATH}/etc/emacs-vterm-zsh.sh ]]
then
	source ${EMACS_VTERM_PATH}/etc/emacs-vterm-zsh.sh
fi

# ** eat

if [[ -n "$EAT_SHELL_INTEGRATION_DIR" ]]; then
   source "$EAT_SHELL_INTEGRATION_DIR/zsh"
fi

# * pre-zimfw

# Highlighters files are sourced at load time; must be set before init.
ZSH_HIGHLIGHT_HIGHLIGHTERS=(main brackets)

# Set `ZSH_AUTOSUGGEST_MANUAL_REBIND` to disable automatic widget re-binding
# on each precmd. This can be a big boost to performance, but you'll need
# to handle re-binding yourself if any of the widget lists change or if you
# or another plugin wrap any of the autosuggest widgets. To re-bind widgets,
# run `_zsh_autosuggest_bind_widgets`.
ZSH_AUTOSUGGEST_MANUAL_REBIND=1
ZSH_AUTOSUGGEST_STRATEGY=(match_prev_cmd history completion)

zstyle ':zim:completion' dumpfile "${XDG_CACHE_HOME}/zsh/zcompdump"

# * zimfw

ZIM_CONFIG_FILE="$ZDOTDIR/.zimrc"
ZIM_HOME="$ZDOTDIR/.zim"

# Download zimfw plugin manager if missing.
if [[ ! -e ${ZIM_HOME}/zimfw.zsh ]]; then
    curl -fsSL --create-dirs -o ${ZIM_HOME}/zimfw.zsh \
         https://github.com/zimfw/zimfw/releases/latest/download/zimfw.zsh
fi

# Install missing modules and update ${ZIM_HOME}/init.zsh if missing or outdated.
if [[ ! ${ZIM_HOME}/init.zsh -nt ${ZIM_CONFIG_FILE} ]]; then
  source ${ZIM_HOME}/zimfw.zsh init
fi

# Initialize modules.
source ${ZIM_HOME}/init.zsh

# * post-zimfw
# Configs that should be after init.zsh to win over zimfw defaults.

setopt extended_glob

setopt auto_cd              # Go to folder path without using cd.
setopt auto_pushd           # Push old directory onto stack on cd.
setopt pushd_ignore_dups    # Do not store duplicates in the stack.
setopt pushd_silent         # Do not print directory stack after pushd/popd.

# Exchanges the meanings of `+` and `-` when used with a number to specify
# a directory in the stack.
setopt pushd_minus

# –Ě–Ķ–Ľ—Ć–∑—Ź –≤–≤–ĺ–ī–ł—ā—Ć –Ņ—É—ā–ł –ī–Ľ—Ź –ļ–ĺ–ľ–į–Ĺ–ī—č `cd` (–ł–Ľ–ł –Ī–Ķ–∑ –Ĺ–Ķ—Ď, –Ķ—Ā–Ľ–ł –ł—Ā–Ņ–ĺ–Ľ—Ć–∑—É–Ķ—ā—Ź –ĺ–Ņ—Ü–ł—Ź
# `auto_cd`) –≤ –ī–ĺ–ľ–į—ą–Ĺ–Ķ–Ļ –ī–ł—Ä–Ķ–ļ—ā–ĺ—Ä–ł–ł –Ī–Ķ–∑ ~/ –≤ –Ĺ–į—á–į–Ľ–Ķ.
unsetopt cdable_vars

# With this option the > redirection, if file exists, truncates it to zero
# length. So unset it we NOT allows > redirection to truncate existing files.
# This way >! or >| must be used to truncate a file.
unsetopt clobber

setopt interactive_comments # Allow comments in interactive shells.
setopt nomatch              # Error on unmatched glob patterns.
unsetopt beep               # Seriously why does this shit even exist!?
setopt combining_chars      # Combine zero-length punctuation with base character.
setopt rc_quotes            # Allow 'it''s' instead of 'it'\''s'.

# ** Jobs

setopt long_list_jobs       # List jobs in long format.
setopt auto_resume          # Resume existing job before creating new process.
setopt notify               # Report background job status immediately.
unsetopt bg_nice            # Don't run background jobs at lower priority.
unsetopt hup                # Don't kill jobs on shell exit.
unsetopt check_jobs         # Don't report running jobs on shell exit.

# ** Correct

setopt correct              # Spell-correct command names only (not all args).
setopt prompt_subst         # Allow expansion in prompts.

CORRECT_IGNORE_FILE='.*'

# –ö–ĺ–ľ–į–Ĺ–ī–į, –ļ–ĺ—ā–ĺ—Ä–į—Ź –Ī—É–ī–Ķ—ā –≤—č–∑–≤–į–Ĺ–į, –Ķ—Ā–Ľ–ł –Ņ–Ķ—Ä–Ķ–Ĺ–į–Ņ—Ä–į–≤–Ľ–Ķ–Ĺ–ł–Ķ stdin –ł—Ā–Ņ–ĺ–Ľ—Ć–∑–ĺ–≤–į—ā—Ć –Ī–Ķ–∑
# –≤–≤–ĺ–ī–į –ļ–ĺ–ľ–į–Ĺ–ī—č: < file.txt
READNULLCMD='less'

# –ē—Ā–Ľ–ł –≤ —Ā–Ľ–ĺ–≤–Ķ –Ķ—Ā—ā—Ć –ĺ—ą–ł–Ī–ļ–į, –Ņ—Ä–Ķ–ī–Ľ–ĺ–∂–ł—ā—Ć –ł—Ā–Ņ—Ä–į–≤–ł—ā—Ć –Ķ—Ď.
SPROMPT="–ě—ą–ł–Ī–ļ–į! –≤–≤–Ķ—Ā—ā–ł %r –≤–ľ–Ķ—Ā—ā–ĺ %R? ([Y]es/[N]o/[E]dit/[A]bort) "

# ** History

HISTFILE="$XDG_CACHE_HOME/zsh/zsh_history"

setopt bang_hist              # Treat ! specially during expansion.
setopt inc_append_history     # Write history immediately, not when the shell exits.
setopt hist_reduce_blanks     # Remove superfluous blanks before recording entry.
setopt hist_verify            # Don't execute immediately upon history expansion.
setopt hist_no_store          # Remove the history command (fc -i) from history.
setopt hist_find_no_dups      # Do not display a line previously found.
setopt hist_ignore_dups       # Don't record an entry that was just recorded again.
setopt hist_ignore_space      # Don't record an entry starting with a space.
setopt hist_expire_dups_first # Delete duplicates first when HISTFILE exceeds HISTSIZE.

zshaddhistory() {
  whence ${${(z)1}[1]} >/dev/null || return 2
}

# ** Completion
# *** Completion menu

# Activate menu when there is ‚Č•1 match (zimfw default has no threshold).
zstyle ':completion:*' menu select=1

# –ü—Ä–ł –ľ–Ĺ–ĺ–∂–Ķ—Ā—ā–≤–Ķ –≤–į—Ä–ł–į—ā–Ĺ–ĺ–≤ –Ņ–ĺ–ī—Ā—ā–į–Ĺ–ĺ–≤–ļ–ł –Ņ–ĺ –Ĺ–į–∂–į—ā–ł—é <Tab> –ĺ—ā–ļ—Ä–ĺ–Ķ—ā –ľ–Ķ–Ĺ—é –ł –Ņ–ĺ–ī—Ā—ā–į–≤–ł—ā
# –Ņ–Ķ—Ä–≤—č–Ļ –≤–į—Ä–ł–į–Ĺ—ā. –ü—Ä–ł –Ņ–ĺ–≤—ā–ĺ—Ä–Ĺ–ĺ–ľ –Ĺ–į–∂–į—ā–ł–ł –Ņ–ĺ–ī—Ā—ā–į–≤–ł—ā —Ā–Ľ–Ķ–ī—É—é—Č–ł–Ļ –≤–į—Ä–ł–į–Ĺ—ā. –í –ľ–Ķ–Ĺ—é
# –ľ–ĺ–∂–Ĺ–ĺ –Ņ–ĺ–Ľ—Ć–∑–ĺ–≤–į—ā—Ć—Ā—Ź —Ā—ā—Ä–Ķ–Ľ–ļ–į–ľ–ł.
setopt menu_complete

# Keys in completion menu
# -----------------------
# The `vi-*` names below are zsh's own built-in widget names for the
# `menuselect` keymap, defined by `zsh/complist`. They have no relation
# to any vi functionality.
bindkey -M menuselect 'h' vi-backward-char
bindkey -M menuselect 'k' vi-up-line-or-history
bindkey -M menuselect 'l' vi-forward-char
bindkey -M menuselect 'j' vi-down-line-or-history
bindkey -M menuselect '^f' vi-forward-word
bindkey -M menuselect '^b' vi-backward-word
bindkey -M menuselect '^[[Z' reverse-menu-complete
bindkey -M menuselect '^[' send-break

# *** Groups and descriptions

zstyle ':completion:*:*:-command-:*:*' group-order aliases builtins functions commands

# Style the group names
#                 underline              end bold
#                ~v                     ~v
#  $'%F{yellow}%B%U%{\e[3m%}%d%{\e[23m%}%b%u%f'
#              ~^  ^~~~~~~~~  ^~~~~~~~~~  ~^
#            bold  italic     end italic   end underline
#
#  zstyle ':completion:*' format $' %F{yellow}%B%{\e[3m%}%d%{\e[23m%}%b%f'

zstyle ':completion:*:default' list-prompt '%S%M matches%s'

zstyle ':completion:*:corrections'  format '%F{green}!- %d (errors: %e) -!%f'
zstyle ':completion:*:descriptions' format '%F{blue}%B-- %d --%b%f'
zstyle ':completion:*:messages'     format ' %F{yellow} -- %d --%f'
zstyle ':completion:*:warnings'     format ' %F{magenta}-- no matches found --%f'

# *** Completion settings

setopt list_packed          # Completion menu takes less space.
setopt complete_aliases     # Complete aliases as separate commands.
setopt glob_complete        # Complete after glob * instead of expanding it.
unsetopt flow_control       # Disable start/stop characters in shell editor.

# By default, the cursor goes at the end of the word when completion start.
# Setting this will not move the cursor and the completion will happen on both
# end of the word completed.
setopt complete_in_word

# Define completers: file extensions first, then standard, then approximate.
zstyle ':completion:*' completer _extensions _complete _approximate

zstyle ':completion::complete:*' cache-path "${XDG_CACHE_HOME}/zsh/zcompcache"

# Autocomplete options for cd rather than the directory stack.
zstyle ':completion:*' complete-options true

# `cd` will never select the parent (e.g. cd ../<TAB>); order of directory sources.
zstyle ':completion:*:cd:*' ignore-parents parent pwd

# Directories
zstyle ':completion:*:*:cd:*' tag-order local-directories directory-stack path-directories
zstyle ':completion:*:-tilde-:*' group-order 'named-directories' 'path-directories' 'users' 'expand'

# Completing process IDs with menu selection.
zstyle ':completion:*:kill:*' force-list always

# Complete processes for the current user only.
zstyle ':completion:*:processes' command 'ps -au$USER'

# For killall: show all running commands, deduplicated.
zstyle ':completion:*:processes-names' command 'ps c -u ${USER} -o command | uniq'

# git checkout: don't sort branches (preserve recency order).
zstyle ':completion:*:git-checkout:*' sort false

# zcompile: ignore backup and already-compiled files.
zstyle ':completion:*:*:zcompile:*' ignored-patterns '(*~|*.zwc)'

# Don't complete backup files as executables.
zstyle ':completion:*:complete:-command-::commands' ignored-patterns '*\~'

# Allow 1 error per 3 characters typed, capped at 7 errors total.
zstyle -e ':completion:*:approximate:*' \
       max-errors 'reply=($((($#PREFIX+$#SUFFIX)/3>7?7:($#PREFIX+$#SUFFIX)/3))numeric)'

# ** Keybindings

# Enable zhs-helix-mode, but not when running in Emacs.
[[ -z "$INSIDE_EMACS" ]] && source ${ZDOTDIR}/helix-mode.zsh

bindkey '^k' history-substring-search-up
bindkey '^j' history-substring-search-down

bindkey \` autosuggest-accept

# Alt+h ‚ÄĒ show man page for the current command.
bindkey '\eh' run-help

# Alt+1..5 ‚ÄĒ insert nth word from the previous command.
bindkey -s '\e1' "!:0-0 \t"
bindkey -s '\e2' "!:1-1 \t"
bindkey -s '\e3' "!:2-2 \t"
bindkey -s '\e4' "!:3-3 \t"
bindkey -s '\e5' "!:4-4 \t"

# ** Aliases

if (( $+commands[eza] )); then
  alias ls='eza -F --group-directories-first'
  alias ll='ls -l --git'      # Long format, git status
fi

if (( $+commands[nvim] )); then
  alias vim='nvim'
  alias vimdiff='nvim -d'
fi

# On Debian/Ubuntu the fd binary is renamed fdfind.
if [[ $(grep -Es '^ID_LIKE=.*(ubuntu|debian)' /etc/os-release) ]]; then
  alias fd=fdfind
fi

# gg is not provided by zimfw's git module.
alias gg='git log --all --oneline --graph --decorate'

# Filesystem navigation shortcuts.
alias ..=' cd ..'
alias ...=' cd ../..'
alias ....=' cd ../../..'
alias .....=' cd ../../../..'

alias mkdir='nocorrect mkdir -vp'
alias mv='nocorrect mv -v'
alias cp='nocorrect cp -vR'
alias rm='nocorrect rm -v'
alias df='df -h'
alias du='du -h'
alias wget='wget -c'
alias ping='ping -c 1'
alias tree='tree -I .git -I .github'
alias cls='clear'
alias help='run-help'
alias -g L='| less'

alias :q='exit'
alias :Q='exit'

alias history_clear_dups="awk '!visited[\$0]++' $XDG_CACHE_HOME/zsh/zsh_history | sponge $XDG_CACHE_HOME/zsh/zsh_history"
alias history_stat="history 0 | awk '{print \$2}' | sort | uniq -c | sort -n -r | head"

